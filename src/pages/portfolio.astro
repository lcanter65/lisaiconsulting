---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const pageTitle = 'Portfolio | lisAIconsulting';
const pageDescription =
  'Selected examples of AI-enabled workflow design, automation, and business process improvement.';

const n8nImages = [
  {
    src: '/images/portfolio/form.png',
    alt: 'Defect intake form used to capture issue details.',
    caption:
      'Step 1 — Intake form: structured capture of defect details to ensure consistent inputs.',
  },
  {
    src: '/images/portfolio/workflow.png',
    alt: 'n8n workflow showing automation process.',
    caption:
      'Step 2 — Workflow automation: n8n processes and routes the intake into a structured flow.',
  },
  {
    src: '/images/portfolio/sheet.png',
    alt: 'Google Sheet output for tracking.',
    caption:
      'Step 3 — Shared tracking: submissions are recorded in a centralized sheet for visibility and follow-up.',
  },
];

const gptImages = [
  {
    src: '/images/portfolio/gpt-1-messy-request.png',
    alt: 'Initial messy user request before clarification.',
    caption:
      'Step 1 — Raw request: the interaction begins with an unstructured business request.',
  },
  {
    src: '/images/portfolio/gpt-2-clarifying-questions.png',
    alt: 'GPT asking clarifying questions.',
    caption:
      'Step 2 — Clarification: targeted questions gather missing business context.',
  },
  {
    src: '/images/portfolio/gpt-3-user-answers.png',
    alt: 'User answers providing detail.',
    caption:
      'Step 3 — Context captured: responses provide the necessary detail for structured output.',
  },
  {
    src: '/images/portfolio/gpt-4-structured-output.png',
    alt: 'Final structured output.',
    caption:
      'Step 4 — Structured output: the request is transformed into a clear, decision-ready summary.',
  },
];
---

<html lang="en">
  <head>
    <BaseHead title={pageTitle} description={pageDescription} />
  </head>
  <body>
    <Header />
    <main class="portfolio-page">
      <section class="hero">
        <p class="eyebrow">Portfolio</p>
        <h1>Examples of practical AI, automation, and workflow design</h1>
        <p class="intro">
          These examples reflect the kind of work I design and deliver: structured intake,
          process improvement, and lightweight automation that solve real business problems
          without unnecessary complexity.
        </p>
      </section>

      <section class="portfolio-grid">
        <div class="section-intro">
          <h2>Selected work</h2>
          <p>
            Two examples are shown below: workflow automation and structured AI-assisted intake.
            Together they demonstrate how I bring clarity, structure, and execution to business processes.
          </p>
        </div>

        <!-- n8n CASE -->
        <article class="case-study">
          <div class="case-header">
            <p class="case-kicker">Example 1</p>
            <h2>n8n Defect Intake & Tracking Automation</h2>
          </div>

          <p>
            This workflow transforms a manual defect intake process into a consistent,
            trackable operating model. A structured form captures inputs, n8n routes the data,
            and results are recorded in a shared tracking system.
          </p>

          <div class="detail-grid">
            <div>
              <h3>Business problem</h3>
              <p>
                Inconsistent defect reporting creates rework, slows triage, and reduces visibility.
              </p>
            </div>
            <div>
              <h3>Approach</h3>
              <p>
                Standardized intake and automated routing using n8n with a shared tracking output.
              </p>
            </div>
            <div>
              <h3>Value</h3>
              <p>
                Cleaner inputs, reduced manual handling, and improved visibility across teams.
              </p>
            </div>
          </div>

          <div class="callout">
            <strong>What it demonstrates:</strong>
            translating a manual process into a structured, repeatable workflow.
          </div>

          <div class="demo-block">
            <h3>Demo walkthrough</h3>
            <p>
              End-to-end flow from intake to tracking:
            </p>

            <div class="image-grid image-grid-three">
              {n8nImages.map((image) => (
                <figure class="image-card">
                  <img src={image.src} alt={image.alt} loading="lazy" />
                  <figcaption>{image.caption}</figcaption>
                </figure>
              ))}
            </div>
          </div>
        </article>

        <!-- GPT CASE -->
        <article class="case-study">
          <div class="case-header">
            <p class="case-kicker">Example 2</p>
            <h2>Business Intake & Prioritization GPT</h2>
          </div>

          <p>
            This solution improves intake quality by guiding users through clarification before producing
            a structured, decision-ready summary.
          </p>

          <div class="detail-grid">
            <div>
              <h3>Business problem</h3>
              <p>
                Requests are often vague or incomplete, leading to delays and rework.
              </p>
            </div>
            <div>
              <h3>Approach</h3>
              <p>
                AI-driven intake that asks questions first, then structures the request.
              </p>
            </div>
            <div>
              <h3>Value</h3>
              <p>
                Faster prioritization with clearer, more complete inputs.
              </p>
            </div>
          </div>

          <div class="callout">
            <strong>What it demonstrates:</strong>
            AI used to improve process clarity—not just generate content.
          </div>

          <div class="demo-block">
            <h3>Demo walkthrough</h3>
            <p>
              Transformation from vague request to structured output:
            </p>

            <div class="image-grid image-grid-three">
              {gptImages.map((image) => (
                <figure class="image-card">
                  <img src={image.src} alt={image.alt} loading="lazy" />
                  <figcaption>{image.caption}</figcaption>
                </figure>
              ))}
            </div>
          </div>
        </article>
      </section>

      <section class="closing">
        <h2>How I approach this work</h2>
        <p>
          I focus on business-ready solutions: clarify the problem, define the workflow,
          reduce friction, and apply the right level of automation.
        </p>
        <p>
          If your team needs help improving intake, workflow clarity, or execution consistency,
          I’d be glad to discuss it.
        </p>
      </section>
    </main>
    <Footer />
  </body>
</html>
