---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Portfolio | lisAIconsulting">

  <section class="container">
    <h1>Selected Work</h1>
    <p>
      Examples of automation, workflow design, and practical AI-enabled solutions.
    </p>

    <div class="image-grid">
      
      <figure class="image-card">
        <img src="/images/portfolio/workflow.png" alt="n8n workflow" />
        <figcaption>n8n workflow</figcaption>
      </figure>

      <figure class="image-card">
        <img src="/images/portfolio/form.png" alt="Defect intake form" />
        <figcaption>Defect intake form</figcaption>
      </figure>

      <figure class="image-card">
        <img src="/images/portfolio/sheet.png" alt="Tracking output" />
        <figcaption>Tracking output</figcaption>
      </figure>

    </div>
  </section>

  <style>
    .container {
      max-width: 900px;
      margin: 0 auto;
      padding: 2rem 1rem;
    }

    h1 {
      margin-bottom: 0.5rem;
    }

    p {
      margin-bottom: 2rem;
      color: #555;
    }

    .image-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      gap: 1.5rem;
    }

    .image-card {
      border: 1px solid #eee;
      border-radius: 10px;
      overflow: hidden;
      background: #fff;
      box-shadow: 0 2px 6px rgba(0,0,0,0.05);
      transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

    .image-card:hover {
      transform: translateY(-4px);
      box-shadow: 0 8px 20px rgba(0,0,0,0.08);
    }

    .image-card img {
      width: 100%;
      display: block;
    }

    .image-card figcaption {
      padding: 0.75rem;
      font-size: 0.9rem;
      color: #333;
      text-align: center;
    }
  </style>

</Layout>
