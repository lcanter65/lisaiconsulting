---
import HeaderLink from './HeaderLink.astro';
import { SITE_TITLE } from '../consts';
---

<header>
	<nav>

  <HeaderLink href="/">Home</HeaderLink>
  <HeaderLink href="#">Services</HeaderLink>
  <HeaderLink href="/demo">Sample</HeaderLink>
  <HeaderLink href="/aboutLisa">About</HeaderLink>
  <HeaderLink href="/contact">Contact</HeaderLink>
</nav>
</header>
<style>
	
header {
  border-bottom: 1px solid #eee;
  padding: 16px 24px;
  background: white;
}

nav {
  display: flex;
  gap: 24px;
}

nav a {
  color: #333;
}

nav a:hover {
  color: #0b3d91;
}
	.social-links,
	.social-links a {
		display: flex;
	}
	@media (max-width: 720px) {
		.social-links {
			display: none;
		}
	}
</style>
