---
import HeaderLink from './HeaderLink.astro';
import { SITE_TITLE } from '../consts';
---

<header>
	<div class="header-inner">
		<a href="/" class="logo-link">
			<span class="site-title">{SITE_TITLE}</span>
		</a>

		<nav>
			<HeaderLink href="/">Home</HeaderLink>
			<HeaderLink href="#">Services</HeaderLink>
			<HeaderLink href="/demo">Demo</HeaderLink>
			<HeaderLink href="/aboutLisa">About</HeaderLink>
			<HeaderLink href="/contact">Contact</HeaderLink>
		</nav>
	</div>
</header>

<style>
	header {
		border-bottom: 1px solid #eee;
		padding: 16px 24px;
		background: white;
	}

	.header-inner {
		max-width: 1100px;
		margin: 0 auto;
		display: flex;
		justify-content: space-between;
		align-items: center;
		gap: 24px;
	}

	.logo-link {
		text-decoration: none;
	}

	.site-title {
		font-size: 1.2rem;
		font-weight: 700;
		letter-spacing: -0.01em;
		color: #0b3d91;
		white-space: nowrap;
	}

	nav {
		display: flex;
		gap: 24px;
		flex-wrap: wrap;
	}

	nav a {
		color: #333;
		text-decoration: none;
	}

	nav a:hover {
		color: #0b3d91;
	}

	.social-links,
	.social-links a {
		display: flex;
	}

	@media (max-width: 720px) {
		.header-inner {
			flex-direction: column;
			align-items: flex-start;
		}

		nav {
			gap: 16px;
		}

		.social-links {
			display: none;
		}
	}
</style>
